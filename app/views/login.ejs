<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <title>Login</title>
</head>

<body>
  <h2>Trang đăng nhập</h2>
  <form method="POST" action="/login">
    <div>
      <label>Tài khoản:</label>
      <input type="text" name="tk">
    </div>
    <div>
      <label>Mật khẩu:</label>
      <input type="password" name="mk">
    </div>
    <button type="submit">Đăng nhập</button>
  </form>

  <a class="link-button" href="/register">Đăng ký tài khoản</a>
  <a class="back-link" href="/">Quay về trang chủ</a>

</body>

</html>