<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>PShop - Trang chủ</title>

    <link rel="icon" type="image/jpeg" href="/image/Shop_logo.jpg" />
    <link rel="stylesheet" href="/css/home.css" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

    <style>
        .buy-product-btn {
            display: inline-block;
            margin-top: 16px;
            padding: 10px 22px;
            background-color: var(--primary-color);
            color: white;
            text-decoration: none;
            font-weight: 600;
            border: none;
            border-radius: 10px;
            transition: all 0.3s ease;
            cursor: pointer;
        }

        .buy-product-btn:hover {
            background-color: #b71c1c;
            transform: translateY(-2px);
        }

        .buy-product-btn.disabled {
            background-color: #cfcfcf;
            color: #666;
            cursor: not-allowed;
            transform: none;
            pointer-events: none;
        }

        .product-desc {
            margin: 10px 0 0;
            font-size: 14px;
            color: #666;
            min-height: 40px;
            line-height: 1.4;
        }

        .product-loading,
        .product-empty,
        .product-error {
            grid-column: 1 / -1;
            font-size: 18px;
            color: #444;
        }
    </style>
</head>
<body>
    <div class="top-strip" style="background: #f1f1f1; font-size: 13px; padding: 5px 0;">
        <div class="container" style="display: flex; gap: 20px; justify-content: center;">
            <span>Thu cũ giá ngon</span>
            <span>Sản phẩm chính hãng</span>
            <span>Giao nhanh toàn quốc</span>
            <span>Hotline: 1800 2097</span>
        </div>
    </div>

    <header class="topbar">
        <div class="container topbar-inner">
            <a href="/" class="brand">
                <div class="brand-logo">
                    <img src="/image/Shop_logo.jpg" alt="PShop Logo" />
                </div>
                <div class="brand-text">
                    <h2>PShop</h2>
                    <span>Thế giới mua sắm đồ điện tử</span>
                </div>
            </a>

            <form class="search-box" action="/" method="GET">
                <input type="text" name="keyword" placeholder="Bạn muốn mua gì hôm nay?" />
                <button type="submit">Tìm</button>
            </form>

            <div class="header-right" style="display: flex; align-items: center; gap: 15px;">
                <a href="/cart" style="text-decoration: none; color: white; font-weight: 600;">Giỏ hàng</a>
                <a href="/login" class="login-btn">Đăng nhập</a>
            </div>
        </div>
    </header>

    <main>
        <section class="hero">
            <div class="container hero-grid">
                <div class="hero-content">
                    <p class="hero-tag">CỬA HÀNG CÔNG NGHỆ PSHOP</p>
                    <h1>Mua sắm thiết bị điện tử dễ dàng tại PShop</h1>
                    <p>Khám phá điện thoại, laptop và nhiều thiết bị công nghệ mới nhất.</p>
                    <div class="hero-actions">
                        <a href="#products" class="primary-btn">Mua ngay</a>
                        <a href="#contact" class="secondary-btn">Liên hệ</a>
                    </div>
                </div>
                <div class="hero-card">
                    <div class="hero-slider" id="heroSlider">
                        <div class="hero-slide active">
                            <img src="/image/1.jpg" alt="iPhone 15 Pro Max" />
                            <div class="hero-product-info">
                                <h3>iPhone 15 Pro Max</h3>
                                <p>29.990.000đ</p>
                            </div>
                        </div>

                        <div class="hero-slide">
                            <img src="/image/2.jpg" alt="Samsung Galaxy S24" />
                            <div class="hero-product-info">
                                <h3>Samsung Galaxy S24</h3>
                                <p>20.490.000đ</p>
                            </div>
                        </div>

                        <div class="hero-slide">
                            <img src="/image/4.jpg" alt="iPad Gen 10" />
                            <div class="hero-product-info">
                                <h3>iPad Gen 10</h3>
                                <p>11.990.000đ</p>
                            </div>
                        </div>

                        <button type="button" class="hero-slider-btn prev" id="heroPrev" aria-label="Ảnh trước">&#10094;</button>
                        <button type="button" class="hero-slider-btn next" id="heroNext" aria-label="Ảnh tiếp theo">&#10095;</button>

                        <div class="hero-slider-dots" id="heroDots">
                            <button type="button" class="hero-dot active" data-slide="0" aria-label="Chuyển tới ảnh 1"></button>
                            <button type="button" class="hero-dot" data-slide="1" aria-label="Chuyển tới ảnh 2"></button>
                            <button type="button" class="hero-dot" data-slide="2" aria-label="Chuyển tới ảnh 3"></button>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <div class="container products-showcase">
            <section class="product-section" id="products">
                <div class="section-header">
                    <h2>Danh sách sản phẩm</h2>
                    
                </div>

                <div id="homepageProducts" class="product-grid three-columns">
                    <p class="product-loading">Đang tải sản phẩm...</p>
                </div>
            </section>
        </div>
    </main>

    <footer class="footer" id="contact">
        <div class="container footer-inner">
            <div class="footer-col">
                <h3>PShop</h3>
                <p>Thế giới mua sắm đồ điện tử uy tín.</p>
            </div>
            <div class="footer-col">
                <h4>Liên hệ</h4>
                <p>Email: pshop@gmail.com</p>
                <p>Hotline: 1800 2005</p>
            </div>
        </div>
        <div class="footer-bottom">
            © 2026 PShop. All rights reserved.
        </div>
    </footer>

    <script>
    const heroSlides = document.querySelectorAll('#heroSlider .hero-slide');
    const heroDots = document.querySelectorAll('#heroSlider .hero-dot');
    const heroPrev = document.getElementById('heroPrev');
    const heroNext = document.getElementById('heroNext');
    let currentHeroSlide = 0;
    let heroAutoPlay;

    function showHeroSlide(index) {
        currentHeroSlide = (index + heroSlides.length) % heroSlides.length;

        heroSlides.forEach((slide, i) => {
            slide.classList.toggle('active', i === currentHeroSlide);
        });

        heroDots.forEach((dot, i) => {
            dot.classList.toggle('active', i === currentHeroSlide);
        });
    }

    function nextHeroSlide() {
        showHeroSlide(currentHeroSlide + 1);
    }

    function prevHeroSlide() {
        showHeroSlide(currentHeroSlide - 1);
    }

    function startHeroAutoPlay() {
        heroAutoPlay = setInterval(nextHeroSlide, 3500);
    }

    function resetHeroAutoPlay() {
        clearInterval(heroAutoPlay);
        startHeroAutoPlay();
    }

    heroNext.addEventListener('click', () => {
        nextHeroSlide();
        resetHeroAutoPlay();
    });

    heroPrev.addEventListener('click', () => {
        prevHeroSlide();
        resetHeroAutoPlay();
    });

    heroDots.forEach((dot, index) => {
        dot.addEventListener('click', () => {
            showHeroSlide(index);
            resetHeroAutoPlay();
        });
    });

    showHeroSlide(0);
    startHeroAutoPlay();

    function escapeHtml(text) {
        const div = document.createElement("div");
        div.textContent = text || "";
        return div.innerHTML;
    }

    function formatPrice(rawPrice) {
        const numeric = Number(String(rawPrice || "").replace(/[^\d]/g, ""));
        if (!Number.isNaN(numeric) && numeric > 0) {
            return numeric.toLocaleString("vi-VN") + "đ";
        }
        return rawPrice && String(rawPrice).trim() ? rawPrice : "Liên hệ";
    }

    async function loadHomepageProducts() {
        const container = document.getElementById("homepageProducts");
        if (!container) return;

        try {
            const response = await fetch("/homepage");
            if (!response.ok) {
                throw new Error("Không lấy được dữ liệu từ /homepage");
            }

            const html = await response.text();
            const parser = new DOMParser();
            const doc = parser.parseFromString(html, "text/html");

            const rows = Array.from(doc.querySelectorAll("table tbody tr")).filter((row) => {
                return row.querySelectorAll("td").length >= 7;
            });

            if (!rows.length) {
                container.innerHTML = '<p class="product-empty">Chưa có sản phẩm nào trong database.</p>';
                return;
            }

            const cards = rows.map((row) => {
                const cols = row.querySelectorAll("td");

                const imageSrc =
                    cols[0].querySelector("img")?.getAttribute("src") || "/image/1.jpg";

                const actionElement = cols[6].querySelector("button, a");
                const id =
                    actionElement?.getAttribute("data-id") ||
                    cols[1].textContent.trim().replace(/^#/, "");

                const title = cols[2].textContent.trim();
                const description = cols[3].textContent.trim();
                const rawPrice = cols[4].textContent.trim();

                const isDisabled = actionElement
                    ? actionElement.hasAttribute("disabled") || actionElement.disabled
                    : false;

                const buyHtml = isDisabled
                    ? '<span class="buy-product-btn disabled">Hết bán</span>'
                    : `<a href="/homepage/${encodeURIComponent(id)}" class="buy-product-btn">Mua</a>`;

                return `
                    <article class="product-card">
                        <div class="product-image">
                            <img src="${escapeHtml(imageSrc)}" alt="${escapeHtml(title)}" onerror="this.src='/image/1.jpg'" />
                        </div>
                        <h4>${escapeHtml(title)}</h4>
                        <p class="product-desc">${escapeHtml(description)}</p>
                        <span class="price">${escapeHtml(formatPrice(rawPrice))}</span>
                        ${buyHtml}
                    </article>
                `;
            }).join("");

            container.innerHTML = cards;
        } catch (error) {
            console.error("Lỗi tải sản phẩm:", error);
            container.innerHTML = '<p class="product-error">Không tải được sản phẩm từ homepage.</p>';
        }
    }

    loadHomepageProducts();
</script>
</body>
</html>