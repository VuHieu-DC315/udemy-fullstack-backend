<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Sửa tài khoản</title>
  <link rel="stylesheet" href="/css/editUser.css">
</head>
<body>
  <header class="topbar">
    <div class="topbar-left">
      <div class="logo-box">
        <img class="logo-img" src="/image/Shop_logo.jpg" alt="logo">
      </div>
      <div class="brand-text">
        <span class="brand-title">PShop</span>
        <span class="brand-subtitle">Thế giới mua sắm đồ điện tử</span>
      </div>
    </div>

    <a href="/admin/users" class="topbar-back-btn">Quay lại quản lý user</a>
  </header>

  <main class="page-wrap">
    <section class="page-heading">
      <p class="page-kicker">Quản lý người dùng</p>
      <h2>Sửa tài khoản</h2>
      <p class="page-desc">Chỉnh sửa thông tin đăng nhập và vai trò người dùng.</p>
    </section>

    <section class="edit-card">
      <form action="/admin/users/update/<%= user.id %>" method="POST">
        <div class="form-grid">
          <div class="form-group">
            <label for="tk">Tài khoản</label>
            <input id="tk" type="text" name="tk" value="<%= user.tk %>" required>
          </div>

          <div class="form-group">
            <label for="email">Email</label>
            <input id="email" type="email" name="email" value="<%= user.email %>" required>
          </div>

          <div class="form-group">
            <label for="mk">Mật khẩu</label>
            <input id="mk" type="text" name="mk" value="<%= user.mk %>" required>
          </div>

          <div class="form-group">
            <label for="role">Role</label>
            <select id="role" name="role">
              <option value="user" <%= user.role === "user" ? "selected" : "" %>>user</option>
              <option value="admin" <%= user.role === "admin" ? "selected" : "" %>>admin</option>
            </select>
          </div>
        </div>

        <div class="form-actions">
          <button class="btn-primary" type="submit">Cập nhật</button>
          <a class="btn-secondary" href="/admin/users">Hủy</a>
        </div>
      </form>
    </section>
  </main>
</body>
</html>
