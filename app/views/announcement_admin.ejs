<!DOCTYPE html>
<html lang="vi">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Quản lý thông báo</title>
  <link rel="icon" type="image/jpeg" href="/image/Shop_logo.jpg" />
  <link rel="stylesheet" href="/css/announcement_admin.css" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
</head>

<body>
  <header class="topbar">
      <div class="topbar-container">
          <a href="/" class="brand-logo" aria-label="Trang chủ">
              <img src="/image/Shop_logo.jpg" alt="Shop Logo" class="brand-logo-img" />
              <div class="brand-logo-text single">
                  <span class="brand-main">PShop</span>
                  <span class="brand-sub">Thế giới mua sắm đồ điện tử</span>
              </div>
          </a>
      </div>
  </header>

  <main class="page">
    <div class="box">
      <h2>Quản lý thông báo</h2>

      <form method="POST" action="/announcements/admin/announcements">
        <div class="form-group">
          <label>Tiêu đề</label>
          <input type="text" name="title" required>
        </div>

        <div class="form-group">
          <label>Nội dung</label>
          <textarea name="content" rows="4" required></textarea>
        </div>

        <div class="form-group">
          <label>Ngày bắt đầu</label>
          <input type="datetime-local" name="startDate">
        </div>

        <div class="form-group">
          <label>Ngày kết thúc</label>
          <input type="datetime-local" name="endDate">
        </div>

        <label class="checkbox-label">
          <input type="checkbox" name="isPermanent">
          Thông báo vô thời hạn
        </label>

        <button type="submit" class="submit-btn">Đăng thông báo</button>
      </form>

      <hr>

      <h3>Danh sách thông báo</h3>

      <% if (announcements && announcements.length > 0) { %>
        <% announcements.forEach(function(item) { %>
          <div class="announcement-item">
            <h4><%= item.title %></h4>
            <p><%= item.content %></p>
            <p><strong>Bắt đầu:</strong> <%= item.startDate ? item.startDate : "Không có" %></p>
            <p><strong>Kết thúc:</strong> <%= item.endDate ? item.endDate : "Không có" %></p>
            <p><strong>Vô thời hạn:</strong> <%= item.isPermanent ? "Có" : "Không" %></p>
          </div>
        <% }) %>
      <% } else { %>
        <p class="empty-msg">Chưa có thông báo nào.</p>
      <% } %>

      <a href="/admin" class="back-link">Quay lại trang admin</a>
    </div>
  </main>
</body>

</html>
