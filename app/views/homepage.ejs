<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PShop - Homepage</title>
    <link rel="stylesheet" href="/css/homepage.css">
</head>

<body>
    
    <div class="main-navbar">
        <div class="main-navbar-inner">
            <a href="/homepage" class="shop-brand">
                <img src="/image/Shop_logo.jpg" alt="PShop Logo" class="shop-brand-logo">
                <div class="shop-brand-text">
                    <span class="shop-brand-name">PShop</span>
                    <span class="shop-brand-tagline">Thế giới mua sắm đồ điện tử</span>
                </div>
            </a>

            <form class="shop-search" onsubmit="return false;">
                <input type="text" placeholder="Bạn muốn mua gì hôm nay?">
                <button type="submit">Tìm</button>
            </form>

            <div class="shop-actions">
                <a href="/cart" class="nav-cart-link">Giỏ hàng</a>

                <% if (user) { %>
                    <a href="/logout" class="nav-auth-btn">Đăng xuất</a>
                <% } else { %>
                    <a href="/login" class="nav-auth-btn">Đăng nhập</a>
                <% } %>
            </div>
        </div>
    </div>
</header>

    <main class="page-shell">
        <div class="content-stack">

            <% if (announcements && announcements.length > 0) { %>
                <section class="panel">
                    <div class="panel-inner">
                        <div class="section-head">
                            <div class="section-title-wrap">
                                <span class="section-kicker">Announcements</span>
                                <h2 class="section-title">Thông báo mới</h2>
                                <p class="section-subtitle">Ưu đãi và cập nhật nổi bật dành cho khách hàng PShop</p>
                            </div>

                            <% if (hasMoreAnnouncements) { %>
                                <a href="/announcements" class="section-link">Xem thêm</a>
                            <% } %>
                        </div>

                        <div class="announcement-grid">
                            <% announcements.forEach(function(item) { %>
                                <article class="announcement-card">
                                    <span class="announcement-badge">Thông báo</span>
                                    <h3 class="announcement-title"><%= item.title %></h3>
                                    <p class="announcement-content"><%= item.content %></p>

                                    <div class="announcement-meta">
                                        <% if (item.isPermanent) { %>
                                            <div>Thông báo vĩnh viễn</div>
                                        <% } else if (item.startDateVN || item.endDateVN) { %>
                                            <div>
                                                Từ: <%= item.startDateVN || "Không giới hạn" %><br>
                                                Đến: <%= item.endDateVN || "Không giới hạn" %>
                                            </div>
                                        <% } %>
                                    </div>
                                </article>
                            <% }) %>
                        </div>
                    </div>
                </section>
            <% } %>

            <section class="panel product-panel">
                <div class="panel-inner">
                    <div class="section-head">
                        <div class="section-title-wrap">
                    
                            <h2 class="section-title">Danh sách sản phẩm</h2>
                            
                        </div>
                    </div>

                    <% if (tutorials && tutorials.length > 0) { %>
                        <div class="product-table-wrap">
                            <table class="product-table">
                                <thead>
                                    <tr>
                                        <th>Ảnh</th>
                                        <th>ID</th>
                                        <th>Sản phẩm</th>
                                        <th>Mô tả</th>
                                        <th>Giá</th>
                                        <th>Trạng thái</th>
                                        <th>Thao tác</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% tutorials.forEach(function(item) { %>
                                        <tr>
                                            <td>
                                                <div class="product-thumb">
                                                    <img src="/image/<%= item.id %>.jpg" alt="tutorial image">
                                                </div>
                                            </td>
                                            <td>
                                                <span class="id-badge">#<%= item.id %></span>
                                            </td>
                                            <td>
                                                <div class="product-title"><%= item.title %></div>
                                            </td>
                                            <td>
                                                <div class="product-desc"><%= item.description %></div>
                                            </td>
                                            <td>
                                                <span class="price-text">
                                                    <%= Number(item.price || 0).toLocaleString("vi-VN") %>đ
                                                </span>
                                            </td>
                                            <td>
                                                <span class="status-badge <%= item.published ? 'active' : 'inactive' %>">
                                                    <%= item.published ? "Đang bán" : "Ngừng bán" %>
                                                </span>
                                            </td>
                                            <td>
                                                <button
                                                    class="btnBuy buy-btn"
                                                    data-id="<%= item.id %>"
                                                    <%= item.published ? "" : "disabled" %>>
                                                    <%= item.published ? "Mua ngay" : "Ngừng bán" %>
                                                </button>
                                            </td>
                                        </tr>
                                    <% }) %>
                                </tbody>
                            </table>
                        </div>
                    <% } else { %>
                        <div class="empty-state">Hiện chưa có sản phẩm nào để hiển thị.</div>
                    <% } %>
                </div>
            </section>

        </div>
    </main>

    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
    <script>
        $(document).ready(function () {
            $(".btnBuy").click(function () {
                const id = $(this).attr("data-id");
                window.location.href = `${window.location.origin}/homepage/${id}`;
            });
        });
    </script>
</body>

</html>