<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PShop - Homepage</title>

    <link rel="stylesheet" href="/css/homepage.css">

    <!-- Đã gộp style vào file homepage.css -->
</head>

<body data-logged-in="<%= !!user %>">

    <!-- NAVBAR -->
    <div class="main-navbar">
        <div class="main-navbar-inner">
            <a href="/shop" class="shop-brand">
                <img src="/image/Shop_logo.jpg" alt="PShop Logo" class="shop-brand-logo">
                <div class="shop-brand-text">
                    <span class="shop-brand-name">PShop</span>
                    <span class="shop-brand-tagline">Thế giới mua sắm đồ điện tử</span>
                </div>
            </a>

            <form class="shop-search" action="/shop" method="GET">
                <input
                    type="text"
                    name="q"
                    value="<%= typeof q !== 'undefined' ? q : '' %>"
                    placeholder="Bạn muốn mua gì hôm nay?">
                <button type="submit">Tìm</button>
            </form>

            <div class="shop-actions">
                <a href="/cart" class="nav-cart-link">Giỏ hàng</a>

                <% if (user) { %>
                    <a href="/logout" class="nav-auth-btn">Đăng xuất</a>
                <% } else { %>
                    <a href="/login" class="nav-auth-btn">Đăng nhập</a>
                <% } %>
            </div>
        </div>
    </div>

    <main class="page-shell">
        <div class="content-stack">

            <!-- ANNOUNCEMENTS -->
            <section class="panel">
                <div class="panel-inner">
                    <div class="section-head">
                        <div class="section-title-wrap">
                            <span class="section-kicker">Announcements</span>
                            <h2 class="section-title">Thông báo mới</h2>
                            <p class="section-subtitle">Ưu đãi và cập nhật nổi bật dành cho khách hàng PShop</p>
                        </div>

                        <% if (hasMoreAnnouncements) { %>
                            <a href="/announcements" class="section-link">Xem thêm</a>
                        <% } %>
                    </div>

                    <% if (announcements && announcements.length > 0) { %>
                        <div class="announcement-grid">
                            <% announcements.forEach(function(item) { %>
                                <article class="announcement-card">
                                    <span class="announcement-badge">Thông báo</span>
                                    <h3 class="announcement-title"><%= item.title %></h3>
                                    <p class="announcement-content preview"><%= item.content %></p>

                                    <div class="announcement-meta">
                                        <% if (item.isPermanent) { %>
                                            <div>Thông báo vĩnh viễn</div>
                                        <% } else if (item.startDateVN || item.endDateVN) { %>
                                            <div>
                                                Từ: <%= item.startDateVN || "Không giới hạn" %><br>
                                                Đến: <%= item.endDateVN || "Không giới hạn" %>
                                            </div>
                                        <% } %>
                                    </div>

                                    <% if (item.content && item.content.length > 120) { %>
                                        <div class="announcement-actions">
                                            <button
                                                type="button"
                                                class="announcement-readmore"
                                                data-title="<%= item.title %>"
                                                data-content="<%= item.content %>"
                                                data-meta="<%= item.isPermanent ? 'Thông báo vĩnh viễn' : ('Từ: ' + (item.startDateVN || 'Không giới hạn') + ' | Đến: ' + (item.endDateVN || 'Không giới hạn')) %>">
                                                Đọc thêm
                                            </button>
                                        </div>
                                    <% } %>
                                </article>
                            <% }) %>
                        </div>
                    <% } else { %>
                        <div class="empty-state">Hiện chưa có thông báo nào.</div>
                    <% } %>
                </div>
            </section>

            <!-- PRODUCTS -->
            <section class="panel product-panel">
                <div class="panel-inner">
                    <h2 class="section-title">Danh sách sản phẩm</h2>

                    <% if (tutorials && tutorials.length > 0) { %>
                        <div class="product-table-wrap">
                            <table class="product-table">
                                <thead>
                                    <tr>
                                        <th>Ảnh</th>
                                        <th>ID</th>
                                        <th>Sản phẩm</th>
                                        <th>Mô tả</th>
                                        <th>Giá</th>
                                        <th>Trạng thái</th>
                                        <th>Thao tác</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% tutorials.forEach(function(item) { %>
                                        <tr>
                                            <td>
                                                <div class="product-thumb">
                                                    <img src="/image/<%= item.id %>.jpg" alt="<%= item.title %>">
                                                </div>
                                            </td>
                                            <td>
                                                <span class="id-badge">#<%= item.id %></span>
                                            </td>
                                            <td>
                                                <div class="product-title"><%= item.title %></div>
                                            </td>
                                            <td>
                                                <div class="product-desc"><%= item.description %></div>
                                            </td>
                                            <td>
                                                <span class="price-text">
                                                    <%= Number(item.price || 0).toLocaleString("vi-VN") %>đ
                                                </span>
                                            </td>
                                            <td>
                                                <span class="status-badge <%= item.published ? 'active' : 'inactive' %>">
                                                    <%= item.published ? "Đang bán" : "Ngừng bán" %>
                                                </span>
                                            </td>
                                            <td>
                                                <button
                                                    class="btnBuy buy-btn"
                                                    data-id="<%= item.id %>"
                                                    <%= item.published ? "" : "disabled" %>>
                                                    <%= item.published ? "Mua ngay" : "Ngừng bán" %>
                                                </button>
                                            </td>
                                        </tr>
                                    <% }) %>
                                </tbody>
                            </table>
                        </div>
                    <% } else { %>
                        <div class="empty-state">Không tìm thấy sản phẩm phù hợp.</div>
                    <% } %>
                </div>
            </section>

        </div>
    </main>

    <div class="announcement-modal" id="announcementModal" aria-hidden="true">
        <div class="announcement-modal-card" role="dialog" aria-modal="true" aria-labelledby="announcementModalTitle">
            <button type="button" class="modal-close" id="closeAnnouncementModal" aria-label="Đóng">×</button>
            <div class="announcement-modal-meta" id="announcementModalMeta"></div>
            <h3 class="announcement-modal-title" id="announcementModalTitle"></h3>
            <div class="announcement-modal-content" id="announcementModalContent"></div>
        </div>
    </div>

    <!-- JS -->
    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>

    <script>
        const isLoggedIn = document.body.dataset.loggedIn === "true";

        function openAnnouncementModal(title, content, meta) {
            $("#announcementModalTitle").text(title || "Thông báo");
            $("#announcementModalContent").text(content || "");
            $("#announcementModalMeta").text(meta || "");
            $("#announcementModal").addClass("show").attr("aria-hidden", "false");
            $("body").addClass("modal-open");
        }

        function closeAnnouncementModal() {
            $("#announcementModal").removeClass("show").attr("aria-hidden", "true");
            $("body").removeClass("modal-open");
        }

        $(document).ready(function () {
            $(".btnBuy").on("click", function () {
                const id = $(this).attr("data-id");

                if (!isLoggedIn) {
                    window.location.href =
                        "/login?error=" + encodeURIComponent("Bạn cần đăng nhập để mua hàng");
                    return;
                }

                window.location.href = "/products/" + encodeURIComponent(id);
            });

            $(".announcement-readmore").on("click", function () {
                openAnnouncementModal(
                    $(this).attr("data-title"),
                    $(this).attr("data-content"),
                    $(this).attr("data-meta")
                );
            });

            $("#closeAnnouncementModal").on("click", function () {
                closeAnnouncementModal();
            });

            $("#announcementModal").on("click", function (e) {
                if (e.target === this) {
                    closeAnnouncementModal();
                }
            });

            $(document).on("keydown", function (e) {
                if (e.key === "Escape") {
                    closeAnnouncementModal();
                }
            });
        });
    </script>

</body>

</html>