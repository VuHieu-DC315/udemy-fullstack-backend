<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Đơn hàng của tôi</title>
  <link rel="icon" type="image/jpeg" href="/image/Shop_logo.jpg" />
  <link rel="stylesheet" href="/css/order.css" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    .status-badge-custom {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 110px;
      padding: 8px 12px;
      border-radius: 999px;
      font-size: 13px;
      font-weight: 700;
      text-transform: capitalize;
    }
    .status-pending { background: #fff7ed; color: #c2410c; }
    .status-confirmed { background: #eff6ff; color: #1d4ed8; }
    .status-shipping { background: #faf5ff; color: #7e22ce; }
    .status-completed { background: #ecfdf3; color: #15803d; }
    .status-cancelled { background: #fef2f2; color: #b91c1c; }
    .top-actions.single {
      display: flex;
      align-items: center;
      gap: 12px;
    }
    .top-actions.single a {
      text-decoration: none;
    }
  </style>
</head>

<body>
  <header class="topbar">
    <div class="topbar-container">
      <a href="/" class="brand-logo" aria-label="Trang chủ">
        <img src="/image/Shop_logo.jpg" alt="Shop Logo" class="brand-logo-img" />
        <div class="brand-logo-text single">
          <span class="brand-main">PShop</span>
        </div>
      </a>

      <form class="search-box" onsubmit="return false;">
        <input
          type="text"
          id="orderSearch"
          placeholder="Tìm kiếm theo mã đơn, tên sản phẩm, email, số điện thoại, trạng thái..." />
      </form>

      <nav class="top-actions single">
        <a href="/shop">Về cửa hàng</a>
        <a href="/cart">Giỏ hàng</a>
        <% if (user) { %>
        <a href="/logout">Đăng xuất</a>
        <% } else { %>
        <a href="/login">Đăng nhập</a>
        <% } %>
      </nav>
    </div>
  </header>

  <main class="page">
    <section class="page-header">
      <a href="/shop" class="back-btn" aria-label="Quay lại cửa hàng">←</a>
      <h1>Đơn hàng của tôi</h1>
    </section>

    <section class="orders-panel">
      <div class="panel-head">
        <div class="panel-title-group">
          <p class="panel-label">Lịch sử mua hàng</p>
          <h2>Các đơn bạn đã đặt</h2>
        </div>

        <div class="order-count-card">
          <span class="count-number"><%= orders ? orders.length : 0 %></span>
          <span class="count-label">đơn hàng</span>
        </div>
      </div>

      <% if (orders && orders.length > 0) { %>
        <div class="table-wrap">
          <table class="order-table">
            <thead>
              <tr>
                <th style="width: 60px">ID</th>
                <th style="min-width: 140px">Tên sản phẩm</th>
                <th style="width: 70px">Số lượng</th>
                <th style="min-width: 120px">Email</th>
                <th style="min-width: 110px">Số điện thoại</th>
                <th style="width: 90px">Gốc</th>
                <th style="width: 90px">Voucher</th>
                <th style="width: 110px">Thanh toán</th>
                <th style="width: 110px">Trạng thái</th>
              </tr>
            </thead>

            <tbody id="orderTableBody">
              <% orders.forEach(function(item) { %>
                <tr class="order-row">
                      <td>
                        <span class="id-badge">#<%= item.id %></span>
                      </td>
                      <td class="title-cell"><%= item.title %></td>
                      <td>
                        <span class="qty-badge"><%= item.quantity %></span>
                      </td>
                      <td>
                        <a class="email-link" href="mailto:<%= item.email %>"><%= item.email %></a>
                      </td>
                      <td>
                        <a class="phone-link" href="tel:<%= item.phone %>"><%= item.phone %></a>
                      </td>
                      <td><%= item.originalAmount ? item.originalAmount.toLocaleString('vi-VN') + 'đ' : '-' %></td>
                      <td><%= item.voucherCode || '-' %></td>
                      <td><%= item.finalAmount ? item.finalAmount.toLocaleString('vi-VN') + 'đ' : '-' %></td>
                      <td>
                        <span class="status-badge-custom status-<%= item.status || 'pending' %>">
                          <%= item.status || 'pending' %>
                        </span>
                      </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>

        <div id="noResultMessage" class="no-result" style="display: none;">
          Không tìm thấy đơn hàng phù hợp.
        </div>
      <% } else { %>
        <div class="empty-state">
          <div class="empty-icon">📦</div>
          <h3>Bạn chưa có đơn hàng nào</h3>
          <p>Hãy mua sản phẩm đầu tiên để hệ thống bắt đầu lưu lịch sử đơn hàng của bạn.</p>
          <a href="/shop" class="empty-btn">Đi tới cửa hàng</a>
        </div>
      <% } %>
    </section>
  </main>

  <script>
    const searchInput = document.getElementById("orderSearch");
    const rows = document.querySelectorAll(".order-row");
    const noResultMessage = document.getElementById("noResultMessage");

    if (searchInput) {
      searchInput.addEventListener("input", function () {
        const keyword = this.value.toLowerCase().trim();
        let visibleCount = 0;

        rows.forEach(function (row) {
          const rowText = row.innerText.toLowerCase();

          if (rowText.includes(keyword)) {
            row.style.display = "";
            visibleCount++;
          } else {
            row.style.display = "none";
          }
        });

        if (noResultMessage) {
          noResultMessage.style.display = visibleCount === 0 ? "block" : "none";
        }
      });
    }
  </script>
</body>
</html>