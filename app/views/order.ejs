<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Danh sách đơn hàng</title>
    <link rel="icon" type="image/jpeg" href="/image/Shop_logo.jpg" />
    <link rel="stylesheet" href="/css/order.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
</head>

<body>
    <header class="topbar">
        <div class="topbar-container">
            <a href="/" class="brand-logo" aria-label="Trang chủ">
                <img src="/image/Shop_logo.jpg" alt="Shop Logo" class="brand-logo-img" />
                <div class="brand-logo-text single">
                    <span class="brand-main">PShop</span>
                </div>
            </a>

            <form class="search-box" onsubmit="return false;">
                <input
                    type="text"
                    id="orderSearch"
                    placeholder="Tìm kiếm đơn hàng theo mã, tên sản phẩm, email, số điện thoại..." />
            </form>

            <nav class="top-actions">
                <a href="/admin">Về trang admin</a>
                <a href="/admin/products">Quản lý sản phẩm</a>
                <a href="/logout">Đăng xuất</a>
            </nav>
        </div>
    </header>

    <main class="page">
        <section class="page-header">
            <a href="/admin" class="back-btn" aria-label="Quay lại trang admin">←</a>
            <h1>Danh sách đơn hàng</h1>
        </section>

        <section class="orders-panel">
            <div class="panel-head">
                <div class="panel-title-group">
                    <p class="panel-label">Quản lý đơn hàng</p>
                    <h2>Toàn bộ đơn đặt hàng</h2>
                </div>

                <div class="order-count-card">
                    <span class="count-number"><%= orders ? orders.length : 0 %></span>
                    <span class="count-label">đơn hàng</span>
                </div>
            </div>

            <% if (orders && orders.length > 0) { %>
                <div class="table-wrap">
                    <table class="order-table">
                        <thead>
    <tr>
        <th>ID</th>
        <th>Product ID</th>
        <th>Tên sản phẩm</th>
        <th>Số lượng</th>
        <th>Email khách</th>
        <th>Số điện thoại</th>
        <th>Giá</th>
        <th>Trạng thái</th>
        <th>Cập nhật</th>
    </tr>
</thead>

                        <tbody id="orderTableBody">
                            <% orders.forEach(function(item) { %>
                                <tr class="order-row">
    <td>
        <span class="id-badge">#<%= item.id %></span>
    </td>

    <td>
        <span class="tutorial-id"><%= item.tutorialId %></span>
    </td>

    <td class="title-cell">
        <%= item.title %>
    </td>

    <td>
        <span class="qty-badge"><%= item.quantity %></span>
    </td>

    <td>
        <a class="email-link" href="mailto:<%= item.email %>">
            <%= item.email %>
        </a>
    </td>

    <td>
        <a class="phone-link" href="tel:<%= item.phone %>">
            <%= item.phone %>
        </a>
    </td>

    <td>
        <span class="price-badge">
            <%= item.price ? item.price.toLocaleString('vi-VN', { style: 'currency', currency: 'VND' }) : '-' %>
        </span>
    </td>

    <td>
        <span><%= item.status || "pending" %></span>
    </td>

    <td>
        <form action="/admin/orders/<%= item.id %>/status" method="POST">
            <select name="status">
                <option value="pending" <%= item.status === "pending" ? "selected" : "" %>>pending</option>
                <option value="confirmed" <%= item.status === "confirmed" ? "selected" : "" %>>confirmed</option>
                <option value="shipping" <%= item.status === "shipping" ? "selected" : "" %>>shipping</option>
                <option value="completed" <%= item.status === "completed" ? "selected" : "" %>>completed</option>
                <option value="cancelled" <%= item.status === "cancelled" ? "selected" : "" %>>cancelled</option>
            </select>
            <button type="submit">Lưu</button>
        </form>
    </td>
</tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>

                <div id="noResultMessage" class="no-result" style="display: none;">
                    Không tìm thấy đơn hàng phù hợp.
                </div>
            <% } else { %>
                <div class="empty-state">
                    <div class="empty-icon">📦</div>
                    <h3>Chưa có đơn hàng nào</h3>
                    <p>Dữ liệu orders hiện đang trống.</p>
                    <a href="/tutorials" class="empty-btn">Đi tới trang tutorial</a>
                </div>
            <% } %>
        </section>
    </main>

    <script>
        const searchInput = document.getElementById("orderSearch");
        const rows = document.querySelectorAll(".order-row");
        const noResultMessage = document.getElementById("noResultMessage");

        if (searchInput) {
            searchInput.addEventListener("input", function () {
                const keyword = this.value.toLowerCase().trim();
                let visibleCount = 0;

                rows.forEach(function (row) {
                    const rowText = row.innerText.toLowerCase();

                    if (rowText.includes(keyword)) {
                        row.style.display = "";
                        visibleCount++;
                    } else {
                        row.style.display = "none";
                    }
                });

                if (noResultMessage) {
                    noResultMessage.style.display = visibleCount === 0 ? "block" : "none";
                }
            });
        }
    </script>
</body>

</html>