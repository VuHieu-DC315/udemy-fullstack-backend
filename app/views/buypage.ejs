<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Buy Page</title>
    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>

    <style>
        button:disabled {
            background-color: #ccc;
            cursor: not-allowed;
        }

        #buyModal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.5);
        }

        #buyModal .modal-content {
            width: 400px;
            background: #fff;
            margin: 100px auto;
            padding: 20px;
            border-radius: 8px;
        }
    </style>

    <script>
        $(document).ready(function () {
            $(".btnBuy").click(function () {
                const id = $(this).attr("data-id");
                const title = $(this).attr("data-title");
                const published = $(this).attr("data-published");

                if (published !== "true" && published !== "1") {
                    return;
                }

                $("#buyId").val(id);
                $("#buyTitle").val(title);
                $("#buyQuantity").val(1);

                $("#buyModal").show();
            });

            $("#closeBuyModal").click(function () {
                $("#buyModal").hide();
            });

            $("#confirmBuy").click(function () {
                const tutorialId = $("#buyId").val();
                const title = $("#buyTitle").val();
                const quantity = $("#buyQuantity").val();
                const email = $("#buyEmail").val();
                const phone = $("#buyPhone").val();

                if (!email || !phone) {
                    alert("Vui lòng nhập email và số điện thoại");
                    return;
                }

                $.ajax({
                    url: "/buy",
                    method: "POST",
                    contentType: "application/json",
                    data: JSON.stringify({
                        tutorialId: tutorialId,
                        title: title,
                        quantity: quantity
                    }),
                    success: function (result) {
                        alert("Buy success!");
                        console.log(result);
                        $("#buyModal").hide();
                    },
                    error: function (error) {
                        console.log(">>> buy error:", error);
                        alert("Buy failed!");
                    }
                });
            });
        });
    </script>
</head>

<body>
    <h3>Id: <%= tutorial.id %>
    </h3>

    <img src="/image/<%= tutorial.id %>.jpg" alt="tutorial image" width="200">

    <p>Title: <%= tutorial.title %>
    </p>
    <p>Description: <%= tutorial.description %>
    </p>
    <p>Published: <%= tutorial.published %>
    </p>
    <p>Price: <%= tutorial.price %>
    </p>

    <form action="/cart/add" method="POST">
        <input type="hidden" name="tutorialId" value="<%= tutorial.id %>">
        <button type="submit" <%=tutorial.published ? "" : "disabled" %>>
            Thêm vào giỏ
        </button>
    </form>

    <div style="margin-top: 10px;">
        <a href="/cart">Xem giỏ hàng</a>
    </div>
    <button class="btnBuy" data-id="<%= tutorial.id %>" data-title="<%= tutorial.title %>"
        data-published="<%= tutorial.published %>" <%=tutorial.published ? "" : "disabled" %>
        >
        Buy
    </button>

    <div id="buyModal">
        <div class="modal-content">
            <h3>Buy product</h3>

            <div style="margin-bottom:10px;">
                <label>Id:</label><br>
                <input type="text" id="buyId" readonly style="width:100%;">
            </div>

            <div style="margin-bottom:10px;">
                <label>Title:</label><br>
                <input type="text" id="buyTitle" readonly style="width:100%;">
            </div>

            <div style="margin-bottom:10px;">
                <label>Quantity:</label><br>
                <input type="number" id="buyQuantity" value="1" min="1" style="width:100%;">
            </div>
            <div style="margin-bottom:10px;">
                <label>Email:</label><br>
                <input type="email" id="buyEmail" style="width:100%;">
            </div>

            <div style="margin-bottom:10px;">
                <label>Phone:</label><br>
                <input type="text" id="buyPhone" style="width:100%;">
            </div>

            <button id="confirmBuy">Confirm</button>
            <button id="closeBuyModal">Close</button>
        </div>
    </div>
</body>

</html>